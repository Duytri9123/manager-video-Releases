{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Flask App",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run_flask.py",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "console": "integratedTerminal",
      "env": {
        "FLASK_HOST": "127.0.0.1",
        "FLASK_PORT": "5000",
        "FLASK_DEBUG": "false"
      },
      "justMyCode": false
    },
    {
      "name": "Run Flask (Debug)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run_flask.py",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "console": "integratedTerminal",
      "env": {
        "FLASK_HOST": "127.0.0.1",
        "FLASK_PORT": "5000",
        "FLASK_DEBUG": "true"
      },
      "justMyCode": false
    }
  ]
}
